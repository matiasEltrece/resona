# ============================================================================
# KYMA — Variables de entorno (plantilla)
# ============================================================================
# Copiá este archivo a .env.local y completá los valores.
# Para una instalación nueva (o transferencia a un comprador), TODA la
# configuración de Kyma sale de estas variables — no hay nada hardcodeado.
# ============================================================================

# ─── App ────────────────────────────────────────────────────────────────────
# URL pública donde corre la app (sin barra final).
NEXT_PUBLIC_APP_URL=https://tu-dominio.com

# ─── Supabase (auth + base de datos + storage) ──────────────────────────────
# Crear un proyecto en supabase.com y correr supabase/migrations/001_kyma_complete_schema.sql
NEXT_PUBLIC_SUPABASE_URL=https://xxxx.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJ...
SUPABASE_SERVICE_ROLE_KEY=eyJ...

# ─── Motor de inferencia ────────────────────────────────────────────────────
# mock  → sin GPU, genera un placeholder (para desarrollo/demo)
# modal → OmniVoice real desplegado en Modal (ver gpu/modal_app.py)
INFERENCE_PROVIDER=modal
OMNIVOICE_ENDPOINT=https://<workspace>--kyma-generate.modal.run
OMNIVOICE_API_KEY=

# ─── Beta privada (HTTP Basic Auth) ─────────────────────────────────────────
# Si están vacías, el sitio es público. Si se setean, pide usuario/contraseña.
BASIC_AUTH_USER=
BASIC_AUTH_PASSWORD=

# ─── Pagos (Lemon Squeezy) ──────────────────────────────────────────────────
# Crear tienda + productos en lemonsqueezy.com. Cargar los variant IDs en la
# tabla kyma_plans. Registrar el webhook → /api/webhooks/lemonsqueezy
LEMON_API_KEY=
LEMON_STORE_ID=
LEMON_WEBHOOK_SECRET=
LEMON_TEST_MODE=true
# URLs de checkout hosted (una por plan)
NEXT_PUBLIC_LEMON_CREATOR_BUY_URL=
NEXT_PUBLIC_LEMON_PRO_BUY_URL=
